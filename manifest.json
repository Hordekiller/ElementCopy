{
  "manifest_version": 3,
  "name": "Elementor Extractor",
  "description": "Extracts Elementor widgets, sections, templates, assets, links, images, forms, and metadata from the current page.",
  "version": "1.0.0",
  "action": {
    "default_title": "Elementor Extractor",
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
